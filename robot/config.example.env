# Copy to ~/picrawler-app/.env on the Pi and fill in. NEVER commit the real .env.
# The deploy script (scripts/deploy.sh) already excludes .env from syncing.

# OpenAI key for the voice+video assistant (Phase 6). Leave blank until needed.
OPENAI_API_KEY=

# MCP auth: leave EMPTY for no-auth on the LAN (current choice).
# Set any string to require clients to send  Authorization: Bearer <that string>.
MCP_AUTH_TOKEN=

# MCP server bind address / port / path
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Battery guard thresholds (volts, 2S pack). Movement refused below MIN.
PICRAWLER_MIN_BATTERY_V=6.8
PICRAWLER_WARN_BATTERY_V=7.2
