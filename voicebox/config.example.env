# Copy to ~/voicebox-app/.env on the Pi and edit. NEVER commit the real .env.
# scripts/deploy.sh already excludes .env from syncing.
#
# There is no API key here: every model call goes through your AgentGateway,
# which holds the upstream credentials. Speech stays on the Pi.

# ---- identity -------------------------------------------------------------
VOICEBOX_NAME=Jarvis
# VOICEBOX_SYSTEM_PROMPT=You are ...

# ---- model gateway --------------------------------------------------------
VOICEBOX_GATEWAY_HOST=172.16.10.155
# local | openai | grok
VOICEBOX_DEFAULT_BACKEND=local
VOICEBOX_LOCAL_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
VOICEBOX_GROK_MODEL=grok-4.5
# empty = let the gateway pick its pinned OpenAI model
VOICEBOX_OPENAI_MODEL=
VOICEBOX_MAX_TOKENS=400
VOICEBOX_HISTORY_TURNS=6
VOICEBOX_LLM_TIMEOUT=60
# the local Qwen route is text-only; flip to 1 if you swap in a VL model
VOICEBOX_LOCAL_VISION=0
# Qwen reasoning: off by default. On, it spends the whole token budget thinking
# and often returns an empty answer — slow and useless for a voice box.
VOICEBOX_LOCAL_THINKING=0

# ---- wake word ------------------------------------------------------------
VOICEBOX_WAKE_ENABLED=1
VOICEBOX_WAKE_MODEL=hey_jarvis
VOICEBOX_WAKE_THRESHOLD=0.5

# ---- audio ----------------------------------------------------------------
# index or name from `python assistant.py --list-devices`; blank = system default
VOICEBOX_MIC_DEVICE=
# Where sound comes OUT. "default" follows /etc/asound.conf. Prefer a card
# NAME fragment over an index ("USB Audio", "hifiberry") — indices move across
# reboots. Run `make devices` to see what's available.
VOICEBOX_AUDIO_OUT=default
# Raises the SunFounder HAT's amp pin (GPIO20). Set 0 if you drop the HAT.
VOICEBOX_ENABLE_HAT_SPEAKER=1
# 0-3; higher rejects more background noise but clips soft speech
VOICEBOX_VAD_AGGRESSIVENESS=2
VOICEBOX_SILENCE_TAIL_S=0.8
VOICEBOX_MAX_UTTERANCE_S=15

# ---- local speech models --------------------------------------------------
# tiny.en is 2.5x faster than base.en on a Pi 4 with the same result on short
# commands. Swap to ggml-base.en.bin if you need accuracy over latency.
VOICEBOX_WHISPER_MODEL=/home/smaniak/voicebox-app/models/ggml-tiny.en.bin
VOICEBOX_WHISPER_THREADS=4
# encoder window; 768 covers ~15s of audio and halves inference time vs 1500
VOICEBOX_WHISPER_AUDIO_CTX=768
VOICEBOX_PIPER_BIN=piper
VOICEBOX_PIPER_VOICE=/home/smaniak/voicebox-app/models/en_US-amy-medium.onnx

# ---- camera + music -------------------------------------------------------
VOICEBOX_CAMERA_ENABLED=1
VOICEBOX_MUSIC_DIR=/home/smaniak/voicebox-app/music

# ---- servers --------------------------------------------------------------
# MCP auth: leave EMPTY for no-auth on the LAN (current choice).
# Set any string to require Authorization: Bearer <that string>.
MCP_AUTH_TOKEN=
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
WEB_HOST=0.0.0.0
WEB_PORT=5000
